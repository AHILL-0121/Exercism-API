# Copy this file to .env.local and fill in your values

# Your Exercism API token
# Obtain from: https://exercism.org/settings/api-cli
EXERCISM_API_TOKEN=your_exercism_api_token_here

# Your Exercism username
EXERCISM_USERNAME=your_username_here

# ── Optional profile display fields ──────────────────────────────────────────
# These are shown in the profile card. Not available from the Exercism API,
# so set them here to get a fully personalised dashboard.

# Your display name (defaults to username if omitted)
EXERCISM_DISPLAY_NAME=

# Location string (e.g. "London, UK")
EXERCISM_LOCATION=

# Pronouns (e.g. "He/him/his")
EXERCISM_PRONOUNS=

# Month + year you joined (e.g. "Jan 2023")
EXERCISM_JOINED=

# Direct URL to your avatar image
# e.g. https://assets.exercism.org/avatars/<user_id>/0
EXERCISM_AVATAR_URL=
